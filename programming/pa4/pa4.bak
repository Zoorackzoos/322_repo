#lang racket
(provide (all-defined-out))
(require "pa1.rkt")
(require "pa2.rkt")
(require "pa3.rkt")

;; ============================================================
;; CSCE 322 - PA4 Starter File
;;
;; In this assignment you will:
;;   1. extend your interpreter with user-defined functions using
;;      closures and static scoping
;;   2. add a conditional expression (if)
;;   3. choose one feature from the Part 2 menu and integrate it
;;   4. give your language a name, a file extension, and a runner
;;   5. write a short design document
;;   6. (optional, substantial EC) implement a mutable heap in
;;      pa4-ec.rkt per Lecture 16
;;
;; Parser. The bundle includes a starter pa1.rkt that already
;; supports if / fun / apply. You may use that file as your
;; pa1.rkt or extend your own from PA3. If your Part 2 feature
;; introduces new surface syntax, you must extend the parser
;; yourself either way.
;;
;; Allowed style:
;;   - top-level define only
;;   - recursion
;;   - if / cond
;;   - basic list operations
;;
;; Not allowed:
;;   - let / let*
;;   - lambda
;;   - nested define
;;   - mutation
;;   - loops / map / match / struct / begin
;;
;; Runner script exception (see Part 4):
;;   - call-with-input-file, read, current-command-line-arguments,
;;     display, write, newline, printf are allowed in
;;     run-<yourlang>.rkt ONLY.
;; ============================================================

;; ============================================================
;; Name: Duncan Holmes
;; Language: Triple T (like tung tung tung sahur)
;; Extension: .TTT
;; Chosen Part 2 feature (one from the menu): cond
;; ============================================================

;; ============================================================
;; Environment helpers
;; ============================================================

;; in pa3 i just left the extend alone and did the evaluation ad-hacishly
;; i have to make it a helper here though
(define (pa4-extend-env var val env)
  ;;this should work like it does in worksheets
  ;; p0 = ( x --> 3, y --> 2 )
  ;;but in the more abstract fucky wucky way mr. t says it
  ;; p0 = ( y --> 2 )
  ;; p1 = ( x --> 3, p0 )
  (cons
    (list var val) env
  )
)

(define (pa4-lookup-env var env)
  (cond
    [(null? env) #f]
    [(equal? (car (car env)) var) (car (cdr (car env)))]
    [else (pa4-lookup-env var (cdr env))]
  )
)


;; ============================================================
;; Closure helpers
;; ============================================================

(define (closure? v)
  (and
    (list? v)
    (not (null? v))
    (equal? (car v) 'closure)
  )
)

(define (closure-fname c)  (car (cdr c)))
(define (closure-params c) (car (cdr (cdr c))))
(define (closure-body c)   (car (cdr (cdr (cdr c)))))
(define (closure-env c)    (car (cdr (cdr (cdr (cdr c))))))


;; ============================================================
;; Error helper
;; ============================================================

(define (pa4-error? v)
  (and
    (list? v)
    (not (null? v))
    (equal? (car v) 'err)
  )
)


;; ============================================================
;; Duplicate parameter check
;; ============================================================

(define (has-duplicate? lst)
  (cond
    [(null? lst) #f]
    [(member (car lst) (cdr lst)) #t]
    [else (has-duplicate? (cdr lst))]
  )
)


;; ============================================================
;; Bind parameters to argument values
;; ============================================================

(define (bind-params params vals env)
  (cond
    [(null? params) env]
    [
    else
      (bind-params
        (cdr params)
        (cdr vals)
        (pa4-extend-env (car params) (car vals) env)
      )
    ]
  )
)


;; ============================================================
;; Evaluate argument list left-to-right, short-circuit on error
;; ============================================================

(define (eval-args args env)
  (cond
    [(null? args) '()]
    [else
     (define v (evaluate-prefix-with-env (car args) env))
     (cond
       [(pa4-error? v) v]
       [else
        (define rest (eval-args (cdr args) env))
        (cond
          [(pa4-error? rest) rest]
          [else (cons v rest)])])]))


;; ============================================================
;; AST shape predicates
;; ============================================================

(define (is-var-ast? ast)
  (and (list? ast) (not (null? ast)) (equal? (car ast) 'var)))

(define (is-if-ast? ast)
  (and (list? ast) (not (null? ast)) (equal? (car ast) 'if)))

(define (is-fun-ast? ast)
  (and (list? ast) (not (null? ast)) (equal? (car ast) 'fun)))

(define (is-apply-ast? ast)
  (and (list? ast) (not (null? ast)) (equal? (car ast) 'apply)))

(define (is-cond-ast? ast)
  (and (list? ast) (not (null? ast)) (equal? (car ast) 'cond)))

(define (is-unary-ast? ast)
  (and (list? ast) (= (length ast) 2)
       (or (equal? (car ast) 'not)
           (equal? (car ast) '-)
           (equal? (car ast) '!))))

(define (is-binary-ast? ast)
  (and (list? ast) (= (length ast) 3)
       (or (arithmetic-op? (car ast))
           (boolean-op-prefix? (car ast))
           (comparison-op? (car ast)))))

(define (boolean-op-prefix? x)
  (or (equal? x 'and) (equal? x 'or)))


;; ============================================================
;; fun AST selectors
;; ============================================================

(define (fun-fname-ast e)  (car (car (car (cdr e)))))
(define (fun-params-ast e) (car (cdr (car (car (cdr e))))))
(define (fun-body-ast e)   (car (cdr (car (cdr e)))))
(define (fun-rest-ast e)   (car (cdr (cdr e))))


;; ============================================================
;; apply AST selectors
;; ============================================================

(define (apply-fname-ast e) (car (car (cdr e))))
(define (apply-args-ast e)  (car (cdr (car (cdr e)))))


;; ============================================================
;; cond evaluation
;; cond AST shape: (cond (((c1 e1) (c2 e2) ... (else en))))
;; ============================================================

(define (eval-cond-arms arms env)
  (cond
    [(null? arms) '(err "no cond match")]
    [else
     (define arm (car arms))
     (cond
       ;; else clause
       [(equal? (car arm) 'else)
        (evaluate-prefix-with-env (car (cdr arm)) env)]
       [else
        (define cv (evaluate-prefix-with-env (car arm) env))
        (cond
          [(pa4-error? cv) cv]
          [(equal? cv 'true)
           (evaluate-prefix-with-env (car (cdr arm)) env)]
          [(equal? cv 'false)
           (eval-cond-arms (cdr arms) env)]
          [else '(err "type error")])])]))


;; ============================================================
;; evaluate-prefix-with-env
;; ============================================================

(define (evaluate-prefix-with-env ast env)
  (cond
    ;; Literals
    [(number? ast) ast]
    [(equal? ast 'true) 'true]
    [(equal? ast 'false) 'false]

    ;; Propagate errors
    [(pa4-error? ast) ast]

    ;; Variable lookup
    [(symbol? ast)
     (define v (pa4-lookup-env ast env))
     (cond
       [(equal? v #f) '(err "free variable")]
       [else v])]

    ;; Not a list — shouldn't happen
    [(not (list? ast)) '(err "invalid ast")]

    ;; var binding
    [(is-var-ast? ast)
     (define var-name (car (car (cdr ast))))
     (define var-expr (car (cdr (car (cdr ast)))))
     (define body     (car (cdr (cdr ast))))
     (define val (evaluate-prefix-with-env var-expr env))
     (cond
       [(pa4-error? val) val]
       [else (evaluate-prefix-with-env body (pa4-extend-env var-name val env))])]

    ;; if  -- lazy branches
    [(is-if-ast? ast)
     (define cv (evaluate-prefix-with-env (car (cdr ast)) env))
     (cond
       [(pa4-error? cv) cv]
       [(equal? cv 'true)  (evaluate-prefix-with-env (car (cdr (cdr ast))) env)]
       [(equal? cv 'false) (evaluate-prefix-with-env (car (cdr (cdr (cdr ast)))) env)]
       [else '(err "type error")])]

    ;; fun -- build closure, bind name, evaluate rest
    [(is-fun-ast? ast)
     (define fname  (fun-fname-ast ast))
     (define params (fun-params-ast ast))
     (define body   (fun-body-ast ast))
     (define rest   (fun-rest-ast ast))
     (cond
       [(has-duplicate? params) '(err "duplicate parameter")]
       [else
        (define clos (list 'closure fname params body env))
        (define new-env (pa4-extend-env fname clos env))
        (evaluate-prefix-with-env rest new-env)])]

    ;; apply -- static scoping
    [(is-apply-ast? ast)
     (define fname (apply-fname-ast ast))
     (define arg-exprs (apply-args-ast ast))
     (define looked-up (pa4-lookup-env fname env))
     (cond
       [(equal? looked-up #f) '(err "free variable")]
       [(pa4-error? looked-up) looked-up]
       [(not (closure? looked-up)) '(err "not a function")]
       [else
        (define clos looked-up)
        (define params (closure-params clos))
        (cond
          [(not (= (length params) (length arg-exprs))) '(err "arity mismatch")]
          [else
           (define vals (eval-args arg-exprs env))
           (cond
             [(pa4-error? vals) vals]
             [else
              ;; apply-time rebind for recursion, then bind params
              (define body-env
                (bind-params params vals
                  (pa4-extend-env fname clos (closure-env clos))))
              (evaluate-prefix-with-env (closure-body clos) body-env)])])])]

    ;; cond
    [(is-cond-ast? ast)
     (define arms (car (cdr ast)))
     (eval-cond-arms arms env)]

    ;; unary operators
    [(is-unary-ast? ast)
     (define v (evaluate-prefix-with-env (car (cdr ast)) env))
     (cond
       [(pa4-error? v) v]
       [else (evaluate-prefix v)])]

    ;; binary operators
    [(is-binary-ast? ast)
     (define lv (evaluate-prefix-with-env (car (cdr ast)) env))
     (cond
       [(pa4-error? lv) lv]
       [else
        (define rv (evaluate-prefix-with-env (car (cdr (cdr ast))) env))
        (cond
          [(pa4-error? rv) rv]
          [else (evaluate-prefix (list (car ast) lv rv))])])]

    [else '(err "invalid ast")]))


;; ============================================================
;; evaluate-with-env  (shadows pa3.rkt's version)
;; ============================================================

(define (evaluate-with-env e env)
  (define ast (infix->prefix e))
  (cond
    [(pa4-error? ast) ast]
    [else (evaluate-prefix-with-env ast env)]))
